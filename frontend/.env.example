VITE_GAS_WEB_APP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
# Optional. This is not a true secret in a static Netlify app. Backend must return aggregates only.
VITE_DASHBOARD_TOKEN=replace-if-you-set-DASHBOARD_TOKEN-in-Apps-Script

# Set this after deploying dashboardApi. When present, it takes precedence over Apps Script.
VITE_FIREBASE_API_URL=https://asia-southeast1-YOUR_PROJECT_ID.cloudfunctions.net/dashboardApi

# Firebase web app configuration for administrator sign-in and CSV uploads.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_APP_ID=

# Optional local emulator switch.
VITE_USE_FIREBASE_EMULATORS=false
